{
  "name": "giis-website",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "bootstrap": "^5.3.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "^5.0.1",
    "react-slick": "^0.30.2",
    "slick-carousel": "^1.8.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "transcript-api:db-up": "docker compose up -d",
    "transcript-api:db-down": "docker compose down",
    "make-demo": "node scripts/make-demo.mjs",
    "make-demo:force": "node scripts/make-demo.mjs --force",
    "make-demo:audio": "node scripts/make-demo.mjs --audio-only",
    "make-demo:merge": "node scripts/make-demo.mjs --merge-only",
    "yt:status": "python3 tools/youtube-upload/yt_queue.py status",
    "yt:quota": "bash tools/youtube-upload/upload_approved_sync.sh --quota",
    "yt:upload": "python3 tools/youtube-upload/yt_queue.py upload",
    "yt:upload-approved": "bash tools/youtube-upload/upload_approved_sync.sh --no-sync",
    "yt:upload-approved:sync": "bash tools/youtube-upload/upload_approved_sync.sh",
    "lesson:cc-foundation": "python3 tools/lesson-video/cc_foundation_worker.py",
    "lesson:foundation-daily": "python3 tools/lesson-video/foundation_daily_orchestrator.py",
    "lesson:foundation-daily:dry-run": "python3 tools/lesson-video/foundation_daily_orchestrator.py --dry-run --no-cc --no-upload --skip-network-check",
    "lesson:foundation-gate": "python3 tools/lesson-video/foundation_video_gate.py",
    "lesson:video-dashboard": "python3 tools/lesson-video/video_dashboard.py",
    "lesson:video-dashboard:live": "node tools/lesson-video/dashboard_server.js",
    "audit:pathways": "node tools/pathway-quality/audit_courses.js",
    "audit:lesson-manifest": "node tools/youtube-upload/audit_manifest_alignment.js",
    "audit:lesson-video-inventory": "node tools/lesson-video/audit_video_quality_inventory.js",
    "normalize:answers": "node tools/pathway-quality/normalize_answer_keys.js",
    "audit:graduation": "node tools/graduation/audit_seed_graduation.js",
    "audit:seniors": "node tools/graduation/audit_senior_records.js",
    "audit:official-docs": "node tools/graduation/audit_official_document_formats.js",
    "audit:personas": "node tools/persona-audit/audit_site.js",
    "postinstall": "node -e \"const fs=require('fs'),f='node_modules/dompurify/dist/purify.es.mjs';try{let c=fs.readFileSync(f,'utf8');fs.writeFileSync(f,c.replace(/\\/\\/#\\s*sourceMappingURL=purify\\.es\\.mjs\\.map/,''));}catch(e){}\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "playwright": "^1.45.0"
  }
}
