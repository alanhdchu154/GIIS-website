# box-monitor.env — config + secrets for box-health-check.sh
# Copy to box-monitor.env ON THE SERVER, fill in, then: chmod 600 box-monitor.env
# This file is git-ignored. Never commit real keys.

# Resend API key used to send alert email (reuse the GIIS Resend key).
RESEND_EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From address (must be on a Resend-verified domain).
MONITOR_FROM_EMAIL=GIIS Server Monitor <monitor@genesisideas.school>

# Used only if recipients.txt is empty.
FALLBACK_EMAIL=alanhdchu@genesisideas.school

# Optional dead-man switch: a Healthchecks.io ping URL. The script pings it on
# success and "<url>/fail" on failure, so you also get alerted if the whole box
# (and this script) dies. Leave blank to disable.
# HEALTHCHECKS_URL=https://hc-ping.com/your-uuid-here

# 1 = try to restart failed APP services (giis-api via pm2, duty-backend via
# systemd). Databases are never auto-restarted.
AUTO_RESTART_APPS=1

# Re-send the alert at most every N seconds while a problem persists (default 6h).
REMIND_SECONDS=21600

# Where the browsable status page is written (served by nginx at /status).
STATUS_HTML=/var/www/status/index.html
