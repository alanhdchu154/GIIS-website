# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

# Server secrets — never commit
server/.env
server/.env.local
server/.env.production

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.claude/
.tmp_pdf_render/

# Demo render artifacts (entire folder) — canonical mp4 + poster live in public/demo/
# auto-deployed by `npm run make-demo`
demo-output/

# Local T9 teaching-video mount. On Alan's workstation this path may be a
# symlink to /Volumes/T9-Active; keep lesson artifacts out of git and publish
# website state through public/data/lessons-manifest.json.
/teaching-videos

# Teaching-video artifacts stay on the T9-backed local mount. These patterns are
# retained for older/non-symlink checkouts and to keep generated outputs out of
# accidental commits. The website-facing durable state is the lesson manifest.
teaching-videos/*/slides/
teaching-videos/*/audio/
teaching-videos/*/audio/*.words.json
teaching-videos/*/__pycache__/
teaching-videos/*/*.mp4
teaching-videos/*/*.wav
teaching-videos/*/*.mp3
teaching-videos/*/*.ass
teaching-videos/*/*.srt
teaching-videos/*/*.mov
teaching-videos/*/*.m4v
teaching-videos/*/*.webm
teaching-videos/*/slides_concat.txt
teaching-videos/*/subtitles.ass
teaching-videos/*/_yt_description.txt
teaching-videos/*/_outline.json
teaching-videos/*/_outline.json.tmp
teaching-videos/*/_outline.failed

# Foundation daily review artifacts generated by the lesson pipeline. Keep the
# canonical release state in script.json, approved_ready_to_upload.json, and the
# lesson manifest; regenerate these review files when auditing a lesson.
teaching-videos/*/_review_*.json
teaching-videos/*/contact-sheet.jpg
teaching-videos/*/learning_check.json
teaching-videos/*/source_packet.json
teaching-videos/*/style_manifest.json
teaching-videos/*/teaching_brief.md
teaching-videos/*/transcript.txt
teaching-videos/*/visual_brief.md

# Cowork API key + other secrets (auto-pipeline reads from here)
.secrets/

# Auto-pipeline scratch — keep summaries (_audit/*-summary.json) tracked, ignore tmp/plans
teaching-videos/*/_audit/*-plan.json
teaching-videos/*/_audit/*.tmp
umi/reviews/cc-runs/*.jsonl
umi/handoffs/*foundation-video*.md

# Lesson-video run snapshots are generated every gate/dashboard run. Commit
# durable review notes or explicit release-gate artifacts instead.
teaching-videos/_audit/dashboard/
teaching-videos/_audit/foundation-daily/*-run.json
teaching-videos/_audit/foundation-daily/latest-run.json
teaching-videos/_audit/lesson-quality/*-lesson-quality.json
teaching-videos/_audit/lesson-quality/*-lesson-quality.md

# FUSE filesystem orphan markers (from sandbox mount activity)
.fuse_hidden*

# Python bytecode (tools/youtube-upload/, tools/lesson-video/)
__pycache__/
*.pyc

# AWS Lightsail SSH private key — never commit
LightsailDefaultKey-us-east-1.pem
*.pem
