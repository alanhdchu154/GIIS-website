# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

# Server secrets — never commit
server/.env
server/.env.local
server/.env.production

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.claude/
.tmp_pdf_render/

# Demo render artifacts (entire folder) — canonical mp4 + poster live in public/demo/
# auto-deployed by `npm run make-demo`
demo-output/

# Teaching videos: keep source-of-truth files in git (script.json,
# build_slides.py, .cleaned breadcrumb). Ignore regenerable artifacts
# (slides PNGs, audio MP3s, MP4 renders, WAV, SRT) — those can be rebuilt
# from script.json + build_slides.py. Cleanup after YouTube upload keeps
# folders slim. See tools/youtube-upload/cleanup_lesson.py.
teaching-videos/*/slides/
teaching-videos/*/audio/
teaching-videos/*/audio/*.words.json
teaching-videos/*/__pycache__/
teaching-videos/*/*.mp4
teaching-videos/*/*.wav
teaching-videos/*/*.mp3
teaching-videos/*/*.ass
teaching-videos/*/*.srt
teaching-videos/*/slides_concat.txt
teaching-videos/*/subtitles.ass
teaching-videos/*/_yt_description.txt
teaching-videos/*/_outline.json
teaching-videos/*/_outline.json.tmp
teaching-videos/*/_outline.failed

# Cowork API key + other secrets (auto-pipeline reads from here)
.secrets/

# Auto-pipeline scratch — keep summaries (_audit/*-summary.json) tracked, ignore tmp/plans
teaching-videos/*/_audit/*-plan.json
teaching-videos/*/_audit/*.tmp
umi/reviews/cc-runs/*.jsonl

# Lesson-video run snapshots are generated every gate/dashboard run. Commit
# durable review notes or explicit release-gate artifacts instead.
teaching-videos/_audit/dashboard/
teaching-videos/_audit/foundation-daily/*-run.json
teaching-videos/_audit/foundation-daily/latest-run.json
teaching-videos/_audit/lesson-quality/*-lesson-quality.json
teaching-videos/_audit/lesson-quality/*-lesson-quality.md

# FUSE filesystem orphan markers (from sandbox mount activity)
.fuse_hidden*

# Python bytecode (tools/youtube-upload/, tools/lesson-video/)
__pycache__/
*.pyc

# AWS Lightsail SSH private key — never commit
LightsailDefaultKey-us-east-1.pem
*.pem
