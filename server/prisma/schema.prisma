generator client {
  provider = "prisma-client-js"
}

// PostgreSQL locally (Docker) and on AWS/Lightsail. Add ?sslmode=require in DATABASE_URL when the host requires TLS — see server/.env.example.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  loginSessions LoginSession[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Student {
  id             String    @id @default(cuid())
  studentCode    String?   @unique
  name           String    @default("")
  birthDate      DateTime?
  gender         String?
  parentGuardian String?
  address        String?
  city           String?
  province       String?
  zipCode        String?
  entryDate      DateTime?
  withdrawalDate DateTime?
  graduationDate DateTime?
  transcriptDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  parentEmail    String?
  account        StudentAccount?
  semesters      Semester[]
  auditLogs      AuditLog[]
  enrollments    Enrollment[]
  parentAccounts ParentAccount[]
  subscriptions  Subscription[]
  loginSessions  LoginSession[]
  careState      StudentCareState?
  careLogs       StudentCareLog[]
}

/// Self-service student login (one account per student record).
///
/// Lock states (from least to most restrictive):
///   normal              isActive=true,  softLocked=false  → full access
///   soft-locked         isActive=true,  softLocked=true   → can sign in + see dashboard,
///                                                            CANNOT take exams or open new modules
///                                                            (set by webhook on 2× payment failure)
///   deactivated         isActive=false                    → cannot sign in at all
///                                                            (set by webhook on refund or admin action)
model StudentAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  softLocked   Boolean  @default(false)
  lockReason   String   @default("") /// "payment_past_due" | "refund_issued" | "admin_hold" | ""
  studentId    String   @unique
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Semester {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// Matches frontend semesterName, e.g. "Grade 9 - Fall Semester"
  key         String
  sortOrder   Int       @default(0)
  /// Grades hidden from students/parents until this date; null = always visible
  releaseDate DateTime?

  courseRows CourseRow[]

  @@unique([studentId, key])
}

model CourseRow {
  id            String   @id @default(cuid())
  semesterId    String
  semester      Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sortOrder     Int      @default(0)
  courseName    String   @default("")
  courseType    String   @default("")
  credits       Decimal?
  letterGrade   String   @default("")
  weightedGpa   Decimal?
  unweightedGpa Decimal?
}

// ─── Course content models ────────────────────────────────────────────────────

model Course {
  id            String               @id @default(cuid())
  slug          String               @unique
  name          String
  nameZh        String               @default("")
  credits       Decimal              @db.Decimal(4, 1)
  department    String
  type          String               @default("Core") // Core | AP | Elective
  gradeLevel    Int? // 9 | 10 | 11 | 12 | null = open to all
  description   String               @default("")
  isPublished   Boolean              @default(false)
  modules       CourseModule[]
  questions     ExamQuestion[]
  quizQuestions ModuleQuizQuestion[]
  enrollments   Enrollment[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model CourseModule {
  id           String  @id @default(cuid())
  courseId     String
  course       Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order        Int
  title        String
  titleZh      String  @default("")
  objectives   String  @default("")
  readingUrl   String  @default("")
  readingNote  String  @default("")
  videoUrl     String  @default("")
  videoNote    String  @default("")
  video2Url    String  @default("")
  video2Note   String  @default("")
  practiceUrl  String  @default("")
  practiceNote String  @default("")
  assignment   String  @default("")
  estimatedHrs Decimal @default(3) @db.Decimal(4, 1)

  @@unique([courseId, order])
}

model ExamQuestion {
  id          String @id @default(cuid())
  courseId    String
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  examType    String @default("final") // "midterm" | "final"
  order       Int    @default(0)
  question    String
  type        String @default("mc") // mc | short
  options     Json?
  answer      String
  explanation String @default("")
  points      Int    @default(1)
}

model Enrollment {
  id               String                 @id @default(cuid())
  studentId        String
  student          Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course                 @relation(fields: [courseId], references: [id])
  enrolledAt       DateTime               @default(now())
  semesterLabel    String                 @default("")
  completedModules Int[]                  @default([])
  creditEarned     Boolean                @default(false)
  creditEarnedAt   DateTime?
  examAttempts     ExamAttempt[]
  quizAttempts     ModuleQuizAttempt[]
  assignments      AssignmentSubmission[]
  moduleProgresses ModuleProgress[]

  @@unique([studentId, courseId])
}

model ModuleProgress {
  id                           String     @id @default(cuid())
  enrollmentId                 String
  enrollment                   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleOrder                  Int
  readingCompletedAt           DateTime?
  videoCompletedAt             DateTime?
  supplementalVideoCompletedAt DateTime?
  practiceCompletedAt          DateTime?
  quizCompletedAt              DateTime?
  assignmentSubmittedAt        DateTime?
  assignmentGradedAt           DateTime?
  moduleCompletedAt            DateTime?
  lastActivityAt               DateTime   @default(now())
  createdAt                    DateTime   @default(now())
  updatedAt                    DateTime   @updatedAt

  @@unique([enrollmentId, moduleOrder])
  @@index([lastActivityAt])
}

model ExamAttempt {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  examType     String     @default("final") // "midterm" | "final"
  startedAt    DateTime   @default(now())
  submittedAt  DateTime?
  score        Decimal?   @db.Decimal(5, 2)
  passed       Boolean?
  answers      Json?
}

model ModuleQuizQuestion {
  id          String @id @default(cuid())
  courseId    String
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleOrder Int
  order       Int
  question    String
  options     Json?
  answer      String
  explanation String @default("")
  points      Int    @default(1)

  @@unique([courseId, moduleOrder, order])
}

model ModuleQuizAttempt {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleOrder  Int
  submittedAt  DateTime   @default(now())
  score        Decimal    @db.Decimal(5, 2)
  passed       Boolean    @default(false)
  answers      Json?

  @@unique([enrollmentId, moduleOrder])
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleOrder  Int
  submittedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  content      String
  feedback     String     @default("")
  score        Decimal?   @db.Decimal(5, 2)
  gradedAt     DateTime?
  gradedById   String?

  @@unique([enrollmentId, moduleOrder])
}

/// One parent can link to multiple students (e.g. siblings, divorced parents with separate accounts).
model ParentAccount {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  loginSessions LoginSession[]
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}

/// Login/session history for student, parent, and admin users.
/// Used for operational care signals: last seen, inactivity, and rough session duration.
model LoginSession {
  id              String         @id @default(cuid())
  role            String /// "student" | "parent" | "admin"
  email           String
  studentId       String?
  student         Student?       @relation(fields: [studentId], references: [id], onDelete: SetNull)
  parentAccountId String?
  parentAccount   ParentAccount? @relation(fields: [parentAccountId], references: [id], onDelete: SetNull)
  adminId         String?
  admin           AdminUser?     @relation(fields: [adminId], references: [id], onDelete: SetNull)
  startedAt       DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  endedAt         DateTime?
  durationSeconds Int            @default(0)
  ipAddress       String         @default("")
  userAgent       String         @default("")
  lastPath        String         @default("")

  @@index([role])
  @@index([email])
  @@index([studentId])
  @@index([parentAccountId])
  @@index([adminId])
  @@index([startedAt])
  @@index([lastSeenAt])
}

/// Staff-only student coordination state. This is the current advisor-owned
/// care snapshot; objective activity signals are still computed from platform data.
model StudentCareState {
  id               String   @id @default(cuid())
  studentId        String   @unique
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  advisorOwner     String   @default("")
  status           String   @default("active") /// active | progressing | slowing_down | disengaging | intervention_needed | advisor_followup | parent_concern
  riskLevel        String   @default("low") /// low | watch | concern | urgent
  careTier         String   @default("self_paced") /// self_paced | guided | premium | transfer | graduation
  manualOverride   Boolean  @default(false)
  lastReviewedAt   DateTime?
  nextCheckInDueAt DateTime?
  currentGoal      String   @default("")
  internalFlags    Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Append-only advisor relationship memory. Internal bodies are admin-only;
/// parent-safe summaries may be exposed later through parent routes.
model StudentCareLog {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type          String   @default("advisor_note") /// advisor_note | weekly_checkin | parent_contact | intervention | transfer_review | graduation_review
  visibility    String   @default("internal") /// internal | parent_safe
  title         String   @default("")
  bodyInternal  String   @default("")
  parentSummary String   @default("")
  channel       String   @default("internal") /// email | phone | wechat | meeting | portal | internal
  outcome       String   @default("")
  followUpAt    DateTime?
  resolvedAt    DateTime?
  authorEmail   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([studentId])
  @@index([type])
  @@index([visibility])
  @@index([followUpAt])
  @@index([resolvedAt])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  role      String /// "student" | "parent"
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([role])
  @@index([expiresAt])
}

/// Prospective student application submitted via /apply.
model Application {
  id                 String    @id @default(cuid())
  studentName        String
  dob                String
  gradeLevel         String
  currentSchool      String    @default("")
  targetUniversities String    @default("")
  preferredLanguage  String    @default("en") // "en" | "zh"
  parentName         String
  parentEmail        String
  phone              String    @default("")
  notes              String    @default("")
  status             String    @default("pending") // pending | approved | rejected
  rejectionReason    String    @default("")
  adminNotes         String    @default("")
  accountsCreated    Boolean   @default(false)
  createdAt          DateTime  @default(now())
  reviewedAt         DateTime?
  reviewedById       String?
}

/// Stripe purchase record. One row per Checkout completion.
///
/// Lifecycle (set by webhook):
///   checkout.session.completed       → row created (or updated), status='active' for subscriptions / status='paid' for one-time
///   customer.subscription.updated    → status / currentPeriodEnd / cancelAtPeriodEnd refreshed
///   customer.subscription.deleted    → status='cancelled'
///   invoice.payment_failed           → status='past_due'
///
/// planType options:
///   self_paced_monthly $49    / month recurring (1 student; legacy founders_monthly/monthly aliases map here)
///   self_paced_annual  $499   / year recurring (1 student)
///   guided_monthly     $149   / month recurring (advisor support)
///   premium_monthly    $299   / month recurring (college-pathway support)
///   group_monthly      inquiry-based legacy/internal cohort tier
///   live_test          $1     one-time (Alan's own end-to-end smoke test)
model Subscription {
  id                      String    @id @default(cuid())
  /// Email entered at Stripe Checkout — may not yet have a ParentAccount.
  purchaserEmail          String
  /// Stripe identifiers
  stripeCustomerId        String?
  stripeSubscriptionId    String?   @unique
  stripePriceId           String?
  stripeCheckoutSessionId String?   @unique
  /// Tier name (see header docs for valid values)
  planType                String
  /// Number of student seats this subscription unlocks
  maxStudents             Int       @default(1)
  /// active | past_due | cancelled | incomplete | trialing | paid | refunded
  status                  String    @default("incomplete")
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  /// USD cents at purchase time (audit; doesn't follow price changes)
  amountTotal             Int?
  /// Set by webhooks-stripe on invoice.payment_failed; resets to 0 when an invoice succeeds.
  paymentFailureCount     Int       @default(0)
  /// Manually linked by admin in /admin/subscriptions (T-107) — connects this purchase to the
  /// specific student account whose access flag we should toggle on payment events.
  studentId               String?
  student                 Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([purchaserEmail])
  @@index([status])
  @@index([planType])
  @@index([studentId])
}

model EmailLog {
  id         String   @id @default(cuid())
  kind       String
  recipient  String
  studentId  String?
  providerId String?
  dedupeKey  String?  @unique
  status     String   @default("sent") /// sent | skipped | error
  error      String   @default("")
  sentAt     DateTime @default(now())

  @@index([kind])
  @@index([recipient])
  @@index([studentId])
  @@index([sentAt])
}

/// Immutable record of admin/student actions on student data.
model AuditLog {
  id         String   @id @default(cuid())
  action     String /// "student_create" | "student_delete" | "profile_update" | "transcript_update"
  studentId  String?
  student    Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  actorRole  String /// "admin" | "student"
  actorEmail String
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
}

/// Idempotency ledger for Stripe webhook delivery. Stripe retries events for up
/// to 3 days and can deliver duplicates; we record each event.id here and skip
/// any event we've already processed so side effects (failure counts, future
/// emails) don't double-fire. See webhooks-stripe.js.
model ProcessedStripeEvent {
  eventId     String   @id /// Stripe event.id (evt_...)
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}
